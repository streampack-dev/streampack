<configuration>
    <!-- Default logback configuration for Streampack modules.
         Downstream modules can override by providing their own logback.xml. -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%-10thread] %-5level %-50.50logger - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="ROLLING" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGFILE_NAME:-output.log}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- rollover daily -->
            <fileNamePattern>${LOGFILE_NAME:-output.log}-%d{yyyy-MM-dd}.%i</fileNamePattern>
            <!-- each file should be at most 10MB, keep 60 days worth of history, but at most 20GB -->
            <maxFileSize>${LOGFILE_MAX_SIZE:-10MB}</maxFileSize>
            <maxHistory>${LOGFILE_TOTAL_COUNT:-5}</maxHistory>
            <totalSizeCap>${LOGFILE_TOTAL_SIZE:-20MB}</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{HH:mm:ss.SSS} [%-10thread] %-5level %-50.50logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Streampack application logging -->
    <logger name="com.enigmastation.streampack" level="DEBUG" />

    <!-- Quiet down noisy frameworks -->
    <logger name="org.hibernate" level="WARN" />
    <logger name="org.hibernate.orm.jdbc.error" level="ERROR" />
    <logger name="org.flywaydb" level="INFO" />
    <logger name="org.springframework" level="INFO" />
    <logger name="org.springframework.integration" level="INFO" />
    <logger name="org.testcontainers" level="INFO" />
    <logger name="com.github.dockerjava" level="WARN" />
    <logger name="tc" level="INFO" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="ROLLING" />
    </root>
</configuration>
